# ── API Keys (required) ─────────────────────────────────────

# Anthropic API key for script generation
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs API key for voiceover generation
# Get one at: https://elevenlabs.io/
ELEVENLABS_API_KEY=xi-...

# ── Optional Configuration ──────────────────────────────────

# ElevenLabs voice ID (default: Rachel - 21m00Tcm4TlvDq8ikWAM)
# Browse voices at: https://elevenlabs.io/voice-library
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ElevenLabs model (default: eleven_multilingual_v2)
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
